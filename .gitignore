# Terraform state — never commit these
*.tfstate
*.tfstate.backup
.terraform/

# Terraform vars contain project IDs and potentially sensitive values
terraform.tfvars

# Terraform crash logs
crash.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# .terraform.lock.hcl is intentionally committed — it pins provider versions
# for reproducible deployments (like package-lock.json)
